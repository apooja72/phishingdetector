{
  "manifest_version": 3,
  "name": "PhishShield Multi-Vector Detector",
  "version": "1.0",
  "description": "Detect phishing URLs, Emails and Attachments",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_url.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content_email.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}